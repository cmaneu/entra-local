{
  "name": "entra-local",
  "version": "0.1.0",
  "private": true,
  "description": "A local, MSAL-compatible emulator of Microsoft Entra ID for application developers.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22.5"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:portal": "vite --config portal/vite.config.ts",
    "build": "npm run build:server && npm run build:portal",
    "build:server": "tsc -p tsconfig.json",
    "build:portal": "node scripts/build-portal.mjs",
    "typecheck": "tsc -p tsconfig.typecheck.json && tsc -p portal/tsconfig.json",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.1.0",
    "@fastify/formbody": "^8.0.2",
    "fastify": "^5.2.0",
    "jose": "^6.2.3",
    "selfsigned": "^2.4.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@azure/msal-browser": "^3.28.1",
    "@azure/msal-node": "^2.16.2",
    "@eslint/js": "^9.18.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.6",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "axe-core": "^4.12.1",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.49.1",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.4.3",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^2.1.8"
  }
}
