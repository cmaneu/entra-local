{
  "name": "entra-local",
  "version": "0.1.0",
  "private": true,
  "description": "A local, MSAL-compatible emulator of Microsoft Entra ID for application developers.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22.5"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build:server && npm run build:portal",
    "build:server": "tsc -p tsconfig.json",
    "build:portal": "node scripts/build-portal.mjs",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "fastify": "^5.2.0",
    "selfsigned": "^2.4.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@azure/msal-browser": "^3.28.1",
    "@azure/msal-node": "^2.16.2",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.6",
    "eslint": "^9.18.0",
    "playwright": "^1.49.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
