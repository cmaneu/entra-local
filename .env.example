# Entra Local — example environment configuration.
# Copy to `.env` (loaded by your process manager) or export these directly.
# Every key is optional; the built-in defaults below match the spec reference table.
# Precedence (highest first): environment variables > entra-local.config.json > defaults.

# --- Server ---
HOST=localhost
PORT=8443
TENANT_ID=11111111-1111-1111-1111-111111111111

# --- Local domains (#26) ---
# Surfaces are served on one shared HTTPS listener, routed by Host header:
#   login.<BASE_DOMAIN>   STS: discovery, JWKS, authorize, token, devicecode, logout
#   portal.<BASE_DOMAIN>  admin portal SPA + Admin REST API + /health
#   graph.<BASE_DOMAIN>   Graph API + OIDC userinfo
# `localhost`/127.0.0.1 stays a backward-compat origin that serves every route.
# Run `entra-local hosts --apply` once so the subdomains resolve to 127.0.0.1.
BASE_DOMAIN=entra.localhost
# Extra apex domains added to the cert SANs and the hosts-file block (comma-separated):
# LOCAL_DOMAINS=contoso.test,fabrikam.test

# ISSUER and the per-surface origins are derived from scheme/BASE_DOMAIN/port/tenant.
# Override individually only when fronted by a proxy:
# ISSUER=https://login.entra.localhost:8443/11111111-1111-1111-1111-111111111111/v2.0
# LOGIN_ORIGIN=https://login.entra.localhost:8443
# PORTAL_ORIGIN=https://portal.entra.localhost:8443
# GRAPH_ORIGIN=https://graph.entra.localhost:8443
# Legacy single-origin mode: PUBLIC_ORIGIN collapses all three origins onto one host.
# PUBLIC_ORIGIN=https://localhost:8443

# --- Persistence (opened by feature #2) ---
DB_PATH=./data/entra-local.db

# --- TLS ---
TLS_ENABLED=true
# Provide BOTH to use a custom certificate (or NEITHER to auto-generate):
# TLS_CERT=./path/to/cert.pem
# TLS_KEY=./path/to/key.pem
TLS_CERT_DIR=./data/tls

# --- Sign-in / seed behavior (consumed by later features) ---
REQUIRE_PASSWORD=false
# SEED_ON_START defaults to "true if DB empty" (decided by #2); set explicitly to force.
# SEED_ON_START=true

# --- Token lifetimes (seconds) ---
TOKEN_LIFETIME_AUTH_CODE_SECONDS=300
TOKEN_LIFETIME_ID_SECONDS=3600
TOKEN_LIFETIME_ACCESS_SECONDS=3600
TOKEN_LIFETIME_REFRESH_SECONDS=86400
TOKEN_LIFETIME_DEVICE_CODE_SECONDS=900
DEVICE_CODE_INTERVAL_SECONDS=5

# --- Graph ---
GRAPH_RESOURCE_ID=https://graph.microsoft.com

# --- Misc ---
LOG_LEVEL=info
# CONFIG_FILE=./entra-local.config.json
NODE_ENV=development
