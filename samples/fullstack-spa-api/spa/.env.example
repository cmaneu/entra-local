# Entra Local — Sample SPA environment reference
#
# Vite auto-loads this file: copy it to `.env` to override any value. All defaults (shown) match the
# emulator's seeded full-stack apps, so the SPA works out of the box with no .env at all.
#
# VITE_EMULATOR_ORIGIN is the loopback compat origin. It only matches the emulator's issuer when the
# emulator runs in compat mode (start it with ORIGIN_MODE=compat, or use this sample's docker
# compose). Since local domains (#26), a plain `npm start` advertises login.entra.localhost instead,
# so the API would reject the token's `iss`. To use the local domains, run `entra-local hosts
# --apply` and set this to the login origin: https://login.entra.localhost:8443.

VITE_EMULATOR_ORIGIN=https://localhost:8443
VITE_TENANT_ID=11111111-1111-1111-1111-111111111111
VITE_CLIENT_ID=cccccccc-0000-0000-0000-000000000004
VITE_API_APP_ID=cccccccc-0000-0000-0000-000000000005
VITE_REDIRECT_URI=http://localhost:5173
VITE_API_BASE=http://localhost:4000
# Where the emulator returns the user after sign-out. Must EXACTLY match a redirect URI registered
# for the SPA app (…0004); the emulator validates it before showing its "Return to application"
# link. Defaults to VITE_REDIRECT_URI.
# VITE_POST_LOGOUT_REDIRECT_URI=http://localhost:5173
# VITE_API_SCOPE defaults to: api://${VITE_API_APP_ID}/access_as_user
# VITE_API_SCOPE=api://cccccccc-0000-0000-0000-000000000005/access_as_user
# VITE_API_ADMIN_SCOPE defaults to: api://${VITE_API_APP_ID}/access_as_admin
# (a second scope requested at sign-in; the API requires access_as_user, so an admin-only token → 403)
# VITE_API_ADMIN_SCOPE=api://cccccccc-0000-0000-0000-000000000005/access_as_admin
