# Entra Local — Sample API environment reference
#
# NOTE: this sample reads values directly from process.env and does NOT auto-load a .env file.
# Either export these in your shell before `npm start`, or use your own loader. Every value has a
# default (shown below) that matches the emulator's seeded full-stack apps.
#
# Certificate trust is automatic: by default the API reads the emulator's dev certificate from the
# repo-root data/tls/cert.pem and trusts it ONLY for the HTTPS JWKS fetch, so you normally don't
# need to set anything. Override the path only if your cert.pem lives elsewhere.

# Path to the emulator's self-signed dev certificate, trusted for the JWKS fetch.
# Relative paths resolve against the directory you run `npm start` from (this api/ folder).
#   - Emulator started with `npm start` from the repo root:  (default, no need to set)
#   - Emulator started with this sample's docker compose:     ../.emulator-data/tls/cert.pem
# EMULATOR_CA_CERT=../.emulator-data/tls/cert.pem

# Optional fallback: still honoured if EMULATOR_CA_CERT is unset (backwards compatibility).
# NODE_EXTRA_CA_CERTS=../../../data/tls/cert.pem

# Optional overrides (defaults shown):
PORT=4000
# EMULATOR_ORIGIN is the loopback compat origin (used to build the issuer the API validates + the
# JWKS URL). It only matches the token's `iss` when the emulator runs in compat mode (start it with
# ORIGIN_MODE=compat, or use this sample's docker compose). Since local domains (#26), a plain
# `npm start` advertises login.entra.localhost, so the token `iss` would be
# https://login.entra.localhost:8443/... and validation would fail. To use the local domains, run
# `entra-local hosts --apply` and set this to the login origin: https://login.entra.localhost:8443.
EMULATOR_ORIGIN=https://localhost:8443
TENANT_ID=11111111-1111-1111-1111-111111111111
API_APP_ID=cccccccc-0000-0000-0000-000000000005
REQUIRED_SCOPE=access_as_user
SPA_ORIGIN=http://localhost:5173
